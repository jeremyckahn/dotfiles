        },
        "gptoss120b": {
          "name": "GPT-OSS 120B",
          "id": "unsloth/gpt-oss-120b-GGUF",
          "limit": {
            "context": 131072,
            "output": 65536
          }
        },
        "qwen30b": {
          "name": "Qwen 30B A30 Coder",
          "id": "unsloth/Qwen3-Coder-30B-A3B-Instruct-GGUF:Q4_K_M",
